generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// -----------------------------------------------------------------------------
// Authentication / NextAuth Base
// -----------------------------------------------------------------------------

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// -----------------------------------------------------------------------------
// Foundational Application Models
// -----------------------------------------------------------------------------

enum Role {
  SUPER_ADMIN
  DEPARTMENT_ADMIN
  STUDENT
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

model User {
  id            String     @id @default(cuid())
  name          String?
  email         String?    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  role          Role       @default(STUDENT)
  status        UserStatus @default(ACTIVE)
  lastLogin     DateTime?
  departmentId  String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  accounts  Account[]
  sessions  Session[]
  auditLogs AuditLog[]
  notifications          Notification[]
  notificationPreference NotificationPreference?

  department Department? @relation("DepartmentAdmins", fields: [departmentId], references: [id], onDelete: SetNull)

  student Student?
}

// -----------------------------------------------------------------------------
// Department Management Module
// -----------------------------------------------------------------------------

enum DepartmentStatus {
  ACTIVE
  INACTIVE
  DELETED
}

model Faculty {
  id          String   @id @default(cuid())
  name        String   @unique
  code        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  departments Department[]
}

model Department {
  id          String           @id @default(cuid())
  name        String           @unique
  code        String           @unique
  description String?
  status      DepartmentStatus @default(ACTIVE)
  facultyId   String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  faculty Faculty? @relation(fields: [facultyId], references: [id], onDelete: SetNull)

  administrators User[] @relation("DepartmentAdmins")

  students  Student[]
  elections Election[]
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  entity    String?
  entityId  String?
  details   String?  @db.Text
  ipAddress String?
  userAgent String?
  outcome   String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
}

// -----------------------------------------------------------------------------
// Student Management Module
// -----------------------------------------------------------------------------

enum StudentStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  GRADUATED
}

model Student {
  id           String        @id @default(cuid())
  matricNo     String        @unique
  fullName     String
  email        String        @unique
  level        Int
  isEligible   Boolean       @default(true)
  status       StudentStatus @default(ACTIVE)
  departmentId String
  userId       String?       @unique
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  department  Department   @relation(fields: [departmentId], references: [id])
  user        User?        @relation(fields: [userId], references: [id])
  candidates  Candidate[]
  voteRecords VoteRecord[]

  @@index([matricNo])
  @@index([email])
  @@index([departmentId])
}

// -----------------------------------------------------------------------------
// Election Management Module
// -----------------------------------------------------------------------------

enum ElectionStatus {
  DRAFT
  SCHEDULED
  PUBLISHED
  VOTING_OPEN
  VOTING_CLOSED
  RESULTS_GENERATED
  PUBLISHED_RESULTS
  ARCHIVED
}

model Election {
  id           String         @id @default(cuid())
  title        String
  description  String?
  departmentId String
  status       ElectionStatus @default(DRAFT)
  startTime    DateTime?
  endTime      DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  department        Department         @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  positions         Position[]
  candidates        Candidate[]
  voteRecords       VoteRecord[]
  anonymizedBallots AnonymizedBallot[]
  electionResults   ElectionResult[]
}

model Position {
  id            String   @id @default(cuid())
  electionId    String
  title         String
  description   String?
  minCandidates Int      @default(1)
  maxCandidates Int      @default(1)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  election          Election           @relation(fields: [electionId], references: [id], onDelete: Cascade)
  candidates        Candidate[]
  voteRecords       VoteRecord[]
  anonymizedBallots AnonymizedBallot[]
  electionResults   ElectionResult[]
}

// -----------------------------------------------------------------------------
// Candidate Management Module
// -----------------------------------------------------------------------------

enum CandidateStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED
  REJECTED
  WITHDRAWN
  DISQUALIFIED
}

model Candidate {
  id         String          @id @default(cuid())
  studentId  String
  electionId String
  positionId String
  status     CandidateStatus @default(PENDING_REVIEW)
  manifesto  String?         @db.Text
  slogan     String?
  photoUrl   String?
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  student           Student            @relation(fields: [studentId], references: [id], onDelete: Cascade)
  election          Election           @relation(fields: [electionId], references: [id], onDelete: Cascade)
  position          Position           @relation(fields: [positionId], references: [id], onDelete: Cascade)
  anonymizedBallots AnonymizedBallot[]
  electionResults   ElectionResult[]

  @@unique([studentId, electionId])
}

// -----------------------------------------------------------------------------
// Voting Engine Module
// -----------------------------------------------------------------------------

model VoteRecord {
  id         String   @id @default(cuid())
  studentId  String
  electionId String
  positionId String
  createdAt  DateTime @default(now())

  student  Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  election Election @relation(fields: [electionId], references: [id], onDelete: Cascade)
  position Position @relation(fields: [positionId], references: [id], onDelete: Cascade)

  @@unique([studentId, electionId, positionId])
}

model AnonymizedBallot {
  id          String   @id @default(cuid())
  electionId  String
  positionId  String
  candidateId String
  createdAt   DateTime @default(now())

  election  Election  @relation(fields: [electionId], references: [id], onDelete: Cascade)
  position  Position  @relation(fields: [positionId], references: [id], onDelete: Cascade)
  candidate Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@index([electionId, positionId, candidateId])
  @@index([electionId])
}

// -----------------------------------------------------------------------------
// Results Engine Module
// -----------------------------------------------------------------------------

model ElectionResult {
  id          String    @id @default(cuid())
  electionId  String
  positionId  String
  candidateId String
  voteCount   Int       @default(0)
  isTie       Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  election  Election  @relation(fields: [electionId], references: [id], onDelete: Cascade)
  position  Position  @relation(fields: [positionId], references: [id], onDelete: Cascade)
  candidate Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
}

// -----------------------------------------------------------------------------
// Notification System
// -----------------------------------------------------------------------------

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String   @db.Text
  type      String
  isRead    Boolean  @default(false)
  priority  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
}

model NotificationPreference {
  id       String @id @default(cuid())
  userId   String @unique
  channels Json

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
